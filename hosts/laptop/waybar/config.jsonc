{
  "include": ["~/.config/waybar/common.jsonc"],
  
  "modules-left": ["cpu", "memory", "network"],
  "modules-center": ["hyprland/workspaces"],
  "modules-right": ["tray", "clock", "upower", "battery"],

"battery": {
  "format": "SYS: {capacity}%", // Label it as System/Laptop
  "format-charging": "⚡ {capacity}%",
  "tooltip": false
  }
}