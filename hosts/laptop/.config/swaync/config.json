{
  "$schema": "/etc/xdg/swaync/configSchema.json",
  "positionX": "right",
  "positionY": "top",
  "control-center-width": 400,
  "fit-to-screen": false,
  "layer": "overlay",
  "control-center-layer": "overlay",
  "cssPriority": "user",
  "notification-body-image-height": 100,
  "notification-body-image-width": 200,

  
  "timeout": 5,
  "timeout-low": 2,
  "timeout-critical": 0,

  
  "widgets": [
    "title", 
    "dnd", 
    "buttons-grid", 
    "volume", 
    "backlight", 
    "mpris", 
    "notifications"
  ],

  "widget-config": {
    "title": { 
      "text": "PILOT HUD", 
      "clear-all-button": true,
      "button-text": "PURGE"
    },
    
    "dnd": {
      "text": "Do Not Disturb"
    },

    "buttons-grid": {
      "buttons-per-row": 3,
      "actions": [
        {
          "label": "󰖩",
          "type": "toggle",
          "active": true,
          "command": "sh -c '[[ $SWAYNC_TOGGLE_STATE == true ]] && nmcli radio wifi on || nmcli radio wifi off'",
          "update-command": "sh -c '[[ $(nmcli radio wifi) == \"enabled\" ]] && echo true || echo false'"
        },
        {
          "label": "󰓅",
          "command": "powerprofilesctl set performance && notify-send 'Core' 'Performance Mode Active'"
        },
        {
          "label": "󱫐",
          "command": "powerprofilesctl set balanced && notify-send 'Core' 'Balanced Mode Engaged'"
        },
        {
          "label": "󰾆",
          "command": "powerprofilesctl set power-saver && notify-send 'Core' 'Power Saver Engaged'"
        },
        {
          "label": "󰄀",
          "command": "grim -g \"$(slurp)\" - | swappy -f -"
        },
       {
          "label": "󰂯",
          "type": "toggle",
          "active": false,
          "command": "sh -c '[[ $SWAYNC_TOGGLE_STATE == true ]] && rfkill unblock bluetooth || rfkill block bluetooth'",
          "update-command": "sh -c 'rfkill list bluetooth | grep -q \"Soft blocked: no\" && echo true || echo false'"
        }
      ]
    },

    
    "volume": {
      "label": "󰕾",
      "show-per-app": true,
      "show-per-app-icon": true,
      "show-per-app-label": false
    },
    "backlight": {
      "label": "󰃠",
      "device": "intel_backlight"
    }
  }
}