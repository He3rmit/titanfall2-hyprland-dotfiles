{
  "$schema": "/etc/xdg/swaync/configSchema.json",
  "positionX": "right",
  "positionY": "top",
  "control-center-width": 400,
  "fit-to-screen": false,
  "layer": "overlay",
  "control-center-layer": "overlay",
  "cssPriority": "user",
  "notification-body-image-height": 100,
  "notification-body-image-width": 200,
  "timeout": 5,
  "timeout-low": 2,
  "timeout-critical": 0,

  "widgets": [
    "title", 
    "dnd", 
    "buttons-grid", 
    "volume", 
    "backlight", 
    "mpris", 
    "notifications"
  ],

  "widget-config": {
    "title": { 
      "text": "PILOT HUD", 
      "clear-all-button": true,
      "button-text": "PURGE"
    },
    
    "dnd": {
      "text": "Do Not Disturb"
    },

   "buttons-grid": {
      "buttons-per-row": 3,
      "actions": [
        {
          "label": "󰖩",
          "type": "toggle",
          "active": false,
          "command": "~/.config/swaync/scripts/pilot-control.sh wifi",
          "update-command": "nmcli radio wifi | grep -q enabled && echo true || echo false"
        },
        {
          "label": "󰂯",
          "type": "toggle",
          "active": false,
          "command": "~/.config/swaync/scripts/pilot-control.sh bluetooth",
          "update-command": "rfkill list bluetooth | grep -q 'Soft blocked: no' && echo true || echo false",
          "interval": 2
        },
        {
          "label": "󰓅",
          "type": "toggle",
          "active": false,
          "command": "~/.config/swaync/scripts/pilot-control.sh perf",
          "update-command": "powerprofilesctl get | grep -q performance && echo true || echo false",
          "interval": 2
        },
        {
          "label": "󱫐",
          "type": "toggle",
          "active": false,
          "command": "~/.config/swaync/scripts/pilot-control.sh bal",
          "update-command": "powerprofilesctl get | grep -q balanced && echo true || echo false",
          "interval": 2
        },
        {
          "label": "󰾆",
          "type": "toggle",
          "active": false,
          "command": "~/.config/swaync/scripts/pilot-control.sh save",
          "update-command": "powerprofilesctl get | grep -q power-saver && echo true || echo false",
          "interval": 2
        },
        {
          "label": "󰄀",
          "command": "bash -c '~/.config/hypr/scripts/screenshot-swappy.sh'",
          "active": false
        }
      ]
    },

    "volume": {
      "label": "󰕾",
      "show-per-app": true,
      "show-per-app-icon": true,
      "show-per-app-label": false
    },

    "backlight": {
      "label": "󰃠"
    },

    "mpris": {
      "image-size": 96,
      "image-radius": 12
    }
  }
}