#!/bin/bash
# ==============================================================================
# PIPELINE: pilot-control
# Purpose: Master utility tool for toggling Pilot HUD specific overrides
# ==============================================================================

show_help() {
    echo -e "\033[1;36mTitanfall Pilot HUD — Master Utility Script\033[0m"
    echo ""
    echo "Usage: pilot-control <module> [action]"
    echo ""
    echo -e "\033[1;33mModules:\033[0m"
    echo "  sddm     Manage the SDDM Cinematic Login Theme"
    echo ""
    echo -e "\033[1;33mActions for 'sddm':\033[0m"
    echo "  --engage     Engages the strict Priority Override for the Cinematic HUD"
    echo "  --restore    Disables the Priority Override to allow KDE/System defaults"
    echo "  --status     Checks current override status"
    echo ""
}

case "$1" in
    sddm)
        case "$2" in
            --engage)
                echo ">> Engaging Cinematic Priority Override..."
                sudo mkdir -p /etc/sddm.conf.d
                sudo ln -sf "$HOME/dotfiles/core/sddm/sddm.conf.d/00-theme.conf" "/etc/sddm.conf.d/00-theme.conf"
                echo -e "\033[1;32m✅ Protocol Active.\033[0m"
                ;;
            --restore)
                echo ">> Restoring Civilian Display Override..."
                if [ -L "/etc/sddm.conf.d/00-theme.conf" ] || [ -f "/etc/sddm.conf.d/00-theme.conf" ]; then
                    sudo rm -f "/etc/sddm.conf.d/00-theme.conf"
                    echo -e "\033[1;32m✅ Priority link removed. SDDM will now fall back to desktop defaults.\033[0m"
                else
                    echo -e "\033[1;33m⚠️ No override found. System is already running default protocols.\033[0m"
                fi
                ;;
            --status)
                if [ -L "/etc/sddm.conf.d/00-theme.conf" ] || [ -f "/etc/sddm.conf.d/00-theme.conf" ]; then
                    echo -e "Status: \033[1;31mENGAGED 🚀\033[0m"
                    echo "Cinematic Protocol is locked in."
                else
                    echo -e "Status: \033[1;34mCIVILIAN 🏠\033[0m"
                    echo "Cinematic Priority is disengaged. Standard defaults apply."
                fi
                ;;
            *)
                echo -e "\033[1;31mUnknown action for sddm: $2\033[0m"
                echo "Use --engage, --restore, or --status"
                exit 1
                ;;
        esac
        ;;
    *)
        show_help
        ;;
esac
