{
  "include": ["~/.config/waybar/common.jsonc"],
  "position": "bottom",
  "width": "auto",
  "height": 40,
  "margin": "10 20 0 20",
  "modules-left": ["hyprland/workspaces"],
  "modules-center": ["clock"],
  "modules-right": ["tray", "custom/peripheral", "custom/power"],

  "hyprland/workspaces": { "format": "{icon}" },
  "clock": { "format": " {:%H:%M}" },
  "custom/peripheral": {
      "exec": "$HOME/dotfiles/core/waybar/scripts/peripheral-monitor.sh --horizontal"
  }
}
